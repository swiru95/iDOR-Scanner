{
  "burp_mcp_url": "http://127.0.0.1:9876/",
  "instruction_prompt": "go to http://127.0.0.1:5000 and obtain token for http://127.0.0.1:5000 use these 3 users",
  "users": [
    {
      "name": "admin_user",
      "variables": {
        "username": "admin_user",
        "password": "admin-pass"
      }
    },
    {
      "name": "editor_user",
      "variables": {
        "username": "editor_user",
        "password": "editor-pass"
      }
    },
    {
      "name": "viewer_user",
      "variables": {
        "username": "viewer_user",
        "password": "viewer-pass"
      }
    }
  ],
  "login_sequence": [
    {
      "request": {
        "method": "POST",
        "url": "http://127.0.0.1:5000/auth/login",
        "json": {
          "username": "{{username}}",
          "password": "{{password}}"
        }
      },
      "extract": {
        "access_token": {
          "from": "json",
          "path": "token"
        }
      }
    }
  ],
  "openapi_spec_path": "example/flask_idor_demo_openapi.json",
  "openapi_path_param_default": "project-alpha",
  "openapi_path_param_defaults": {
    "project_id": "project-alpha",
    "report_id": "report-admin-finance",
    "document_id": "doc-admin-secret",
    "invoice_id": "invoice-admin-001",
    "team_id": "team-core",
    "event_id": "audit-security-001"
  },
  "openapi_operation_path_param_defaults": {
    "deleteProject": {
      "project_id": "project-beta"
    }
  },
  "openapi_expectation_overrides": {
    "getProfile": {
      "allowed_users": [
        "admin_user",
        "editor_user",
        "viewer_user"
      ]
    },
    "getProject": {
      "allowed_users": [
        "admin_user",
        "editor_user",
        "viewer_user"
      ]
    },
    "getProjectSummary": {
      "allowed_users": [
        "admin_user",
        "editor_user",
        "viewer_user"
      ]
    },
    "getTeamMembers": {
      "allowed_users": [
        "admin_user",
        "editor_user",
        "viewer_user"
      ]
    },
    "getReport": {
      "allowed_users": [
        "admin_user"
      ]
    },
    "getDocument": {
      "allowed_users": [
        "admin_user"
      ]
    },
    "getAdminAuditEvent": {
      "allowed_users": [
        "admin_user"
      ]
    }
  },
  "openapi_exclude_operation_ids": [
    "login"
  ]
}
