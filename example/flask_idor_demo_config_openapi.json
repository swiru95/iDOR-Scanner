{
  "instruction_prompt": "go to http://127.0.0.1:5000 and obtain token for http://127.0.0.1:5000 use these 3 users",
  "users": [
    {
      "name": "admin_user",
      "variables": {
        "username": "admin_user",
        "password": "admin-pass"
      }
    },
    {
      "name": "editor_user",
      "variables": {
        "username": "editor_user",
        "password": "editor-pass"
      }
    },
    {
      "name": "viewer_user",
      "variables": {
        "username": "viewer_user",
        "password": "viewer-pass"
      }
    }
  ],
  "login_sequence": [
    {
      "request": {
        "method": "POST",
        "url": "http://127.0.0.1:5000/auth/login",
        "json": {
          "username": "{{username}}",
          "password": "{{password}}"
        }
      },
      "extract": {
        "access_token": {
          "from": "json",
          "path": "token"
        }
      }
    }
  ],
  "openapi_spec_path": "example/flask_idor_demo_openapi.json",
  "openapi_path_param_default": "project-alpha"
}
