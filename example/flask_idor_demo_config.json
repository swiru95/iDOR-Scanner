{
  "users": [
    {
      "name": "admin_user",
      "variables": {
        "username": "admin_user",
        "password": "admin-pass"
      }
    },
    {
      "name": "editor_user",
      "variables": {
        "username": "editor_user",
        "password": "editor-pass"
      }
    },
    {
      "name": "viewer_user",
      "variables": {
        "username": "viewer_user",
        "password": "viewer-pass"
      }
    }
  ],
  "login_sequence": [
    {
      "request": {
        "method": "POST",
        "url": "http://127.0.0.1:5000/auth/login",
        "json": {
          "username": "{{username}}",
          "password": "{{password}}"
        }
      },
      "extract": {
        "access_token": {
          "from": "json",
          "path": "token"
        }
      }
    }
  ],
  "authorization_tests": [
    {
      "name": "me-profile",
      "request": {
        "method": "GET",
        "url": "http://127.0.0.1:5000/api/me/profile",
        "headers": {
          "Authorization": "Bearer {{access_token}}"
        }
      },
      "expectations": {
        "allowed_users": [
          "admin_user",
          "editor_user",
          "viewer_user"
        ]
      }
    },
    {
      "name": "project-read",
      "request": {
        "method": "GET",
        "url": "http://127.0.0.1:5000/api/projects/project-alpha",
        "headers": {
          "Authorization": "Bearer {{access_token}}"
        }
      },
      "expectations": {
        "allowed_users": [
          "admin_user",
          "editor_user",
          "viewer_user"
        ]
      }
    },
    {
      "name": "project-summary-read",
      "request": {
        "method": "GET",
        "url": "http://127.0.0.1:5000/api/projects/project-alpha/summary",
        "headers": {
          "Authorization": "Bearer {{access_token}}"
        }
      },
      "expectations": {
        "allowed_users": [
          "admin_user",
          "editor_user",
          "viewer_user"
        ]
      }
    },
    {
      "name": "admin-report-idor",
      "request": {
        "method": "GET",
        "url": "http://127.0.0.1:5000/api/reports/report-admin-finance",
        "headers": {
          "Authorization": "Bearer {{access_token}}"
        }
      },
      "expectations": {
        "allowed_users": [
          "admin_user"
        ]
      }
    },
    {
      "name": "admin-document-idor",
      "request": {
        "method": "GET",
        "url": "http://127.0.0.1:5000/api/documents/doc-admin-secret",
        "headers": {
          "Authorization": "Bearer {{access_token}}"
        }
      },
      "expectations": {
        "allowed_users": [
          "admin_user"
        ]
      }
    },
    {
      "name": "project-create",
      "request": {
        "method": "POST",
        "url": "http://127.0.0.1:5000/api/projects",
        "headers": {
          "Authorization": "Bearer {{access_token}}"
        },
        "json": {
          "project_id": "project-gamma",
          "name": "Gamma",
          "status": "draft"
        }
      },
      "expectations": {
        "allowed_users": [
          "admin_user",
          "editor_user"
        ]
      }
    },
    {
      "name": "project-comment-create",
      "request": {
        "method": "POST",
        "url": "http://127.0.0.1:5000/api/projects/project-alpha/comments",
        "headers": {
          "Authorization": "Bearer {{access_token}}"
        },
        "json": {
          "message": "Scanner example comment"
        }
      },
      "expectations": {
        "allowed_users": [
          "admin_user",
          "editor_user"
        ]
      }
    },
    {
      "name": "project-update",
      "request": {
        "method": "PUT",
        "url": "http://127.0.0.1:5000/api/projects/project-alpha",
        "headers": {
          "Authorization": "Bearer {{access_token}}"
        },
        "json": {
          "name": "Alpha updated",
          "status": "review"
        }
      },
      "expectations": {
        "allowed_users": [
          "admin_user",
          "editor_user"
        ]
      }
    },
    {
      "name": "project-status-patch",
      "request": {
        "method": "PATCH",
        "url": "http://127.0.0.1:5000/api/projects/project-alpha/status",
        "headers": {
          "Authorization": "Bearer {{access_token}}"
        },
        "json": {
          "status": "released"
        }
      },
      "expectations": {
        "allowed_users": [
          "admin_user",
          "editor_user"
        ]
      }
    },
    {
      "name": "project-delete",
      "request": {
        "method": "DELETE",
        "url": "http://127.0.0.1:5000/api/projects/project-beta",
        "headers": {
          "Authorization": "Bearer {{access_token}}"
        }
      },
      "expectations": {
        "allowed_users": [
          "admin_user"
        ]
      }
    }
  ]
}
