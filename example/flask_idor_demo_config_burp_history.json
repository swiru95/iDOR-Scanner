{
  "instruction_prompt": "verify all requests from burp MCP history",
  "users": [
    {
      "name": "admin_user",
      "variables": {
        "username": "admin_user",
        "password": "admin-pass"
      }
    },
    {
      "name": "editor_user",
      "variables": {
        "username": "editor_user",
        "password": "editor-pass"
      }
    },
    {
      "name": "viewer_user",
      "variables": {
        "username": "viewer_user",
        "password": "viewer-pass"
      }
    }
  ],
  "login_sequence": [
    {
      "request": {
        "method": "POST",
        "url": "http://127.0.0.1:5000/auth/login",
        "json": {
          "username": "{{username}}",
          "password": "{{password}}"
        }
      },
      "extract": {
        "access_token": {
          "from": "json",
          "path": "token"
        }
      }
    }
  ],
  "burp_history_requests": [
    {
      "method": "GET",
      "url": "http://127.0.0.1:5000/api/me/profile"
    },
    {
      "method": "GET",
      "url": "http://127.0.0.1:5000/api/projects/project-alpha"
    },
    {
      "method": "GET",
      "url": "http://127.0.0.1:5000/api/reports/report-admin-finance"
    },
    {
      "method": "GET",
      "url": "http://127.0.0.1:5000/api/documents/doc-admin-secret"
    },
    {
      "method": "GET",
      "url": "http://127.0.0.1:5000/api/admin/audit-events/audit-security-001"
    },
    {
      "method": "GET",
      "url": "http://127.0.0.1:5000/api/invoices/invoice-admin-001"
    },
    {
      "method": "GET",
      "url": "http://127.0.0.1:5000/api/teams/team-core/members"
    }
  ]
}
